#!/usr/bin/env python3
"""StarryNet CLI runner."""

import argparse
import os
import sys
import traceback

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
REPO_ROOT = os.path.dirname(SCRIPT_DIR)
if REPO_ROOT not in sys.path:
    sys.path.insert(0, REPO_ROOT)

if 'PYTHONPATH' in os.environ:
    sys.path = os.environ['PYTHONPATH'].split(':') + sys.path

from starrynet.cli import CLI
from starrynet.log import debug, error, info
from starrynet.sn_synchronizer import StarryNet


def parse_gs(value):
    parts = value.split("/")
    if len(parts) % 2 != 0:
        raise argparse.ArgumentTypeError(
            "GS coordinates must be la1/lo1/la2/lo2")

    coordinates = []
    try:
        for idx in range(0, len(parts), 2):
            coordinates.append([float(parts[idx]), float(parts[idx + 1])])
    except ValueError as exc:
        raise argparse.ArgumentTypeError(str(exc)) from exc
    return coordinates


def build_parser():
    parser = argparse.ArgumentParser(
        description="Start the interactive StarryNet CLI.")
    parser.add_argument(
        "-p", "--path",
        default="./config.json",
        help="path to the JSON configuration file (default: ./config.json)")
    parser.add_argument(
        "-g", "--gs",
        default="50.110924/8.682127/46.635700/14.311817",
        type=parse_gs,
        help="ground-station coordinates as la1/lo1/la2/lo2")
    parser.add_argument(
        "-b", "--bird-conf",
        default="./bird.conf",
        help="default BIRD configuration used by run_routing_daemon")
    parser.add_argument(
        "--clean",
        action="store_true",
        help="connect to configured workers, clean the environment, then exit")
    return parser


def main():
    parser = build_parser()
    args = parser.parse_args()
    if not os.path.exists(args.path):
        parser.error(f"configuration file not found: {args.path}")

    sn = None
    cleaned = False
    try:
        sn = StarryNet(args.path, args.gs)
        if args.clean:
            sn.clean()
            cleaned = True
            return 0

        CLI(sn, default_bird_conf=args.bird_conf)
        return 0
    except KeyboardInterrupt:
        info("\nKeyboard Interrupt. Shutting down...\n")
        return 130
    except Exception as exc:
        error(f"Caught exception: {type(exc).__name__}: {exc}\n")
        debug(traceback.format_exc() + "\n")
        return 1
    finally:
        if sn is not None and not cleaned:
            try:
                sn.clean()
            except Exception as exc:
                error(f"Cleanup failed: {exc}\n")


if __name__ == "__main__":
    raise SystemExit(main())
